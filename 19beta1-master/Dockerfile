ARG CGAL_GIT_BRANCH
ENV CGAL_GIT_BRANCH=${CGAL_GIT_BRANCH}
ENV CGAL_GIT_HASH=3e5b9fcc0e8bda3ebc8f1cca615faf46a84b49c5
ENV SFCGAL_GIT_HASH=eb9a03daaa5eb018f97da82105121487b2c22564
